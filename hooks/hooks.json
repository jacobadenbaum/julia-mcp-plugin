{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__.*julia__julia_eval",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/inject-poller.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/approve-poller.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/inject-poller.py"
          }
        ]
      },
      {
        "matcher": "mcp__.*julia__julia_restart",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/restart-guard.py"
          }
        ]
      }
    ]
  }
}
